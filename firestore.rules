rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    match /games/{gameId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /comments/{commentId} {
      allow read: if true;

      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.gameId is string
        && request.resource.data.userName is string
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 300;

      allow update: if isAdmin();
      allow delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /active_sessions/{sessionId} {
      allow read: if true;

      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.gameId is string
        && request.resource.data.sessionId is string;

      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;

      allow delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /leaderboards/{gameId} {
      allow read: if true;
      allow write: if false;

      match /entries/{uid} {
        allow read: if true;

        allow create: if isOwner(uid)
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.gameId == gameId
          && request.resource.data.bestScore is number
          && request.resource.data.bestScore >= 0
          && request.resource.data.lastScore is number
          && request.resource.data.lastScore >= 0
          && request.resource.data.attempts is number
          && request.resource.data.attempts >= 1;

        allow update: if isOwner(uid)
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.gameId == gameId
          && request.resource.data.bestScore is number
          && request.resource.data.bestScore >= resource.data.bestScore
          && request.resource.data.lastScore is number
          && request.resource.data.lastScore >= 0
          && request.resource.data.attempts is number
          && request.resource.data.attempts >= resource.data.attempts;

        allow delete: if isAdmin();
      }
    }

    match /users/{uid} {
      allow read: if isAdmin() || isOwner(uid);
      allow create: if isOwner(uid);
      allow update: if isAdmin() || isOwner(uid);
      allow delete: if isAdmin();
    }

    match /scores/{scoreId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
